<tool id="count_multi_file" name="Count multi-file selection" version="1.0.0">
    <description>count datasets in a multiple-file input</description>
    <command><![CDATA[
echo '${len($input1)}' > '$out_file1'
    ]]></command>
    <inputs>
        <param name="input1" type="data" multiple="true" label="Datasets to count" />
    </inputs>
    <outputs>
        <data name="out_file1" format="txt" label="Dataset count"/>
    </outputs>
    <tests>
    </tests>
    <help>
    </help>
</tool>
