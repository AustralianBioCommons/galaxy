<tool id="count_list" name="Count list elements" version="1.0.0">
    <description>count items in a list collection</description>
    <command><![CDATA[
echo '${len($input1.keys())}' > '$out_file1'
    ]]></command>
    <inputs>
        <param name="input1" type="data_collection" collection_type="list" label="Input list collection" />
    </inputs>
    <outputs>
        <data name="out_file1" format="txt" label="Element count of ${input1.name}"/>
    </outputs>
    <tests>
    </tests>
    <help>
    </help>
</tool>
